{
  "expo": {
    "name": "Tenalytics",
    "slug": "tenalytics-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/10alytics-iOS-Default-1024x1024@1x.png",
    "scheme": "tenalyticsapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tenalytics.mobile",
      "icon": "./src/assets/images/10alytics.icon",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleDisplayName": "10Alytics"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundImage": "./src/assets/images/adaptive-icon.png",
        "monochromeImage": "./src/assets/images/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tenalytics.mobile",
      "label": "10Alytics"
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-video",
      "expo-router",
      [
        "expo-dev-client",
        {
          "launchMode": "launcher"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-icon-light.png",
          "imageWidth": 200,
          "backgroundColor": "#E6F4FE",
          "dark": {
            "image": "./src/assets/images/splash-icon-dark.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/splash-icon-light.png",
          "color": "#FF6600",
          "defaultChannel": "chat"
        }
      ],
      "expo-web-browser",
      [
        "expo-navigation-bar",
        {
          "enforceContrast": false
        }
      ],
      "expo-status-bar",
      "expo-image",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "ios": {
            "usePrecompiledModules": false
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "c630d574-0ced-4fce-953f-21234b58a631"
      }
    },
    "owner": "tenalytics"
  }
}
