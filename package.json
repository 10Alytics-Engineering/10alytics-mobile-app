{
  "name": "10alytics-mobile",
  "version": "1.0.0",
  "scripts": {
    "android": "CMAKE_VERSION=3.31.6 expo run:android",
    "ios": "REACT_NATIVE_PACKAGER_HOSTNAME=localhost expo run:ios --no-bundler",
    "start": "REACT_NATIVE_PACKAGER_HOSTNAME=localhost expo start --dev-client --localhost",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo-google-fonts/lora": "^0.3.0",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@rn-primitives/slot": "^1.1.0",
    "@rn-primitives/types": "^1.1.0",
    "@tanstack/react-query": "^5.91.2",
    "axios": "^1.13.6",
    "buffer": "^6.0.3",
    "burnt": "^0.13.0",
    "expo": "~56.0.11",
    "expo-apple-authentication": "~56.0.4",
    "expo-asset": "~56.0.17",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.6",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-mesh-gradient": "~56.0.3",
    "expo-navigation-bar": "~56.0.3",
    "expo-notifications": "~56.0.17",
    "expo-router": "~56.2.10",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-video": "~56.1.3",
    "expo-web-browser": "~56.0.5",
    "laravel-echo": "^2.3.4",
    "lottie-react-native": "~7.3.1",
    "lucide-react-native": "^0.562.0",
    "pressto": "^0.6.0",
    "pusher-js": "^8.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-redash": "^18.1.5",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-size-matters": "^0.4.2",
    "react-native-status-bar-height": "^2.6.0",
    "react-native-svg": "15.15.4",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/plugin-proposal-throw-expressions": "^7.25.9",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-universe": "^12.0.1",
    "prettier": "^3.2.5",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "~6.0.3"
  },
  "eslintConfig": {
    "extends": "universe/native",
    "root": true,
    "rules": {
      "prettier/prettier": "off"
    }
  },
  "main": "expo-router/entry",
  "private": true,
  "reanimated": {
    "staticFeatureFlags": {
      "ENABLE_SHARED_ELEMENT_TRANSITIONS": true
    }
  }
}
